

enum CharDevIrqStatus {
    RxComplete(usize),
    IrqOk,
    IrqError(i32)
};

/**
 * @interface ICharDevSend
 * @brief Interface for sending data through a character device.
 */
interface ICharDevSend {
    procedure send(&mut self,
                   nbytes : const usize,
                   output_bytes : &[u8; nbytes], 
                   status : &mut Status<i32>);
};


/**
 * @interface CharDevRecv
 * @brief Interface for receiving data from a character device.
 */
interface ICharDevEnqueue {
    procedure enqueue(&mut self,
                      byte : u8,
                      status : &mut CharDevIrqStatus);
};


/**
 * @interface CharDevDequeue
 * @brief Interface for dequeuing received data from a character device.
 */
interface ICharDevDequeue {
    procedure dequeue(&mut self,
                      byte : &mut Option<u8>);
};


/**
 * @interface ICharDevNotifyIrq 
 * @brief Interface for handling UART-related IRQ operations.
 */
interface ICharDevNotifyIrq {
    procedure notify_irq(&mut self,
                         result : &mut CharDevIrqStatus);
};
